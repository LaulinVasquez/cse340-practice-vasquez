<%- include("partials/header") %>
<main>
    <div class="course-header">
        <h1><%= course.title %></h1>
        <p class="course-meta"><%= course.id %> • <%= course.credits %> credits</p>
        <p class="course-description"><%= course.description %></p>
    </div>

    <div class="sections">
        <div class="sections-header">
            <h2>Available Sections</h2>
<div class="sort-options">
    <span>Sort by: </span>
    <a href="/catalog/<%= course.slug %>?sort=time"class="<%= currentSort === 'time' ? 'active' : '' %>">Time</a>
    <a href="/catalog/<%= course.slug %>?sort=professor" class="<%= currentSort === 'professor' ? 'active' : '' %>">Professor</a>
    <a href="/catalog/<%= course.slug %>?sort=room" class="<%= currentSort === 'room' ? 'active' : '' %>">Room</a>
</div>
        </div>

        <div class="section-list">
            <% sections.forEach(section => { %>
                <div class="section-card">
                    <div class="section-time"><%= section.time %></div>
                    <div class="section course"><strong>course name:</strong> <%= section.courseName %></div>
                    <div class="section professor"><strong>Instructor:</strong> <%= section.professor %></div>
                    <div class="section room">Room: <%= section.room %></div>
                    <div class="section department">department: <%= section.department %></div>
                </div>
            <% }); %>
        </div>
    </div>
    <div class="navigation">
        <p><a href="/catalog">&larr; Back to Course Catalog</a></p>
    </div>
</main>
<%- include("partials/footer") %>